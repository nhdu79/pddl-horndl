(define (domain Test)
(:constants
  a - object)
(:predicates
  (preda ?x - object)
  (predb ?x - object)
  (predc ?x - object)
  (predd ?x - object)
  (AUX0)
  (AUX1)
  (AUX2)
  (AUX3))
(:derived (predd ?x0 - object)
          (and (preda ?x0) (AUX1)))
(:derived (AUX0)
          (forall (?x1 - object) (predc ?x1)))
(:derived (AUX1)
          (or (predb ?x0) (AUX0)))
(:derived (AUX2)
          (or (predb ?x) (predc ?x)))
(:derived (AUX3)
          (and (preda ?x) (AUX2)))
(:action add
  :parameters (?x - object)
  :precondition (and (forall (?x1 - object) (predc ?x1)) (not (preda ?x)))
  :effect (when (exists (?x - object) (AUX3)) (and (preda ?x) (predb ?x))))
)