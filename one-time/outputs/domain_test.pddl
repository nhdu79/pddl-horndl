(define (domain Test)
(:constants
  a - object
  b - object
  c - object)
(:predicates
  (preda ?x - object)
  (predb ?x - object)
  (predc ?x - object)
  (predd ?x - object)
  (prede ?x - object)
  (predf ?x - object)
  (predg ?x - object)
  (AUX0 ?x - object)
  (AUX1 ?x - object)
  (AUX2 ?x - object))
(:derived (predg ?x - object)
          (or (AUX1 ?x) (AUX2 ?x)))
(:derived (AUX0 ?x - object)
          (exists (?y - object) (or (predb ?y) (predc ?x))))
(:derived (AUX1 ?x - object)
          (and (AUX0 ?x) (preda ?x)))
(:derived (AUX2 ?x - object)
          (and (predd ?x) (prede ?x)))
)